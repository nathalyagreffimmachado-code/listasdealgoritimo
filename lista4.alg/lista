algoritmo "multiplos de 3 "

var
  valor:inteiro
  resto:inteiro 

inicio
valor<-3
enquanto  valor <= 30 faca 
resto<- valor mod 3
se resto = 0 entao
escreval (valor)
fimse 
valor<-1 +valor
fimenquanto
fimalgoritmo
