algoritmo "verificar numero"

var
   numero:real

inicio
escreva("digite um numero ")
   leia(numero)
   escreva("digite um numero ")
   leia(numero)
se numero > 0 entao
escreva("o numero é positivo" )
senao
se numero <0 entao
escreva ("o numero é negativo")
senao
escreva("o numero é zero")
fimse
fimse


fimalgoritmo