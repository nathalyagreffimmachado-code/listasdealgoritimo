algoritmo "seq_b"
 
var
   i: inteiro
   soma: real
 
inicio
   i <- 1
   soma <- 0
 
   enquanto i < 100 faca
      soma <- soma + (i / (i + 1))
      i <- i + 1
   fimenquanto
 
   escreval("Resultado: ", soma)
 
fimalgoritmo

//----------------- EXERCICIO 7 ----------------//
algoritmo "fibonacci"
 
var
   a, b, c, contador: inteiro
 
inicio
   a <- 0
   b <- 1
   contador <- 1
 
   escreva(a, " ", b, " ")
 
   enquanto contador <= 8 faca
      c <- a + b
      escreva(c, " ")
 
      a <- b
      b <- c
 
      contador <- contador + 1
   fimenquanto
 
fimalgoritmo
