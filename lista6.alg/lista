///-------- EXERCICIO 6 -------------//
algoritmo "Exercício 6 - Matriz 3x3"
var
   mat: vetor [1..3, 1..3] de inteiro
   l, c: inteiro
inicio
   para l de 1 ate 3 faca
      para c de 1 ate 3 faca
         escreva("Digite valor para [", l, ",", c, "]: ")
         leia(mat[l,c])
      fimpara
   fimpara
   escreval("--- Matriz Formatada ---")
   para l de 1 ate 3 faca
      para c de 1 ate 3 faca
         escreva(mat[l,c]:4) // :4 dá um espaçamento entre os números
      fimpara
      escreval("") // Pula linha ao fim de cada linha da matriz
   fimpara
fimalgoritmo
