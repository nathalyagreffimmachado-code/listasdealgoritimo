//--------- EXERCICIO 8 ----------//
algoritmo "Exercício 8 - Diagonal Principal"
var
   mat: vetor [1..3, 1..3] de inteiro
   l, c, somaDiag: inteiro
inicio
   somaDiag <- 0
   para l de 1 ate 3 faca
      para c de 1 ate 3 faca
         escreva("Valor [", l, ",", c, "]: ")
         leia(mat[l,c])
         se (l = c) entao
            somaDiag <- somaDiag + mat[l,c]
         fimse
      fimpara
   fimpara
   escreval("Soma da diagonal principal: ", somaDiag)
fimalgoritmo
//--------- EXERCICIO 9 -----------//
algoritmo "Exercício 9 - Maior Valor Matriz"
var
   mat: vetor [1..4, 1..4] de inteiro
   l, c, maior: inteiro
inicio
   para l de 1 ate 4 faca
      para c de 1 ate 4 faca
         escreva("Valor [", l, ",", c, "]: ")
         leia(mat[l,c])
         se (l = 1) e (c = 1) entao
            maior <- mat[l,c]
         senao
            se (mat[l,c] > maior) entao
               maior <- mat[l,c]
            fimse
         fimse
      fimpara
   fimpara
   escreval("O maior valor encontrado foi: ", maior)
fimalgoritmo
//-------- EXERCICIO 10 ---------//
algoritmo "Exercício 10 - Média por Linha"
var
   mat: vetor [1..3, 1..4] de real
   l, c: inteiro
   somaLinha, media: real
inicio
   para l de 1 ate 3 faca
      somaLinha <- 0
      escreval("--- Digite os valores da linha ", l, " ---")
      para c de 1 ate 4 faca
         escreva("Coluna ", c, ": ")
         leia(mat[l,c])
         somaLinha <- somaLinha + mat[l,c]
      fimpara
      media <- somaLinha / 4
      escreval("Média da linha ", l, " é: ", media:5:2)
      escreval("")
   fimpara
fimalgoritmo