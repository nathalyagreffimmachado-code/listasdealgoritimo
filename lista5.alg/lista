//------------- EXERCICIO 3 -------------//
algoritmo "CalcularFatorial"

 

var

   // n: número digitado pelo usuário

   // i: contador para o laço

   // fat: variável para armazenar o resultado acumulado

   n, i, fat: inteiro

 

inicio

   Escreva("Digite um valor inteiro e positivo: ")

   Leia(n)

 

   // Inicializamos 'fat' com 1, pois é o elemento neutro da multiplicação

   fat <- 1

 

   // Se o usuário digitar 0, o fatorial é 1 por definição.

   // O laço Para só executará se n for maior ou igual a 1.

   para i de 1 ate n faca

      fat <- fat * i

   fimpara

 

   Escreval("O fatorial de ", n, " é: ", fat)

 

fimalgoritmo
